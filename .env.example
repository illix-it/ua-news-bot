# =========================
# Telegram
# =========================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =========================
# General bot settings
# =========================
DRY_RUN=true
MAX_POSTS_PER_RUN=1
POLL_INTERVAL_SECONDS=60

# =========================
# Initial / startup behavior
# =========================
INIT_SKIP_EXISTING=false
INIT_POST_LATEST=false

# =========================
# Dedup
# =========================
DEDUP_DB_PATH=data/seen.sqlite3
RESET_DEDUP_ON_START=false
DRY_RUN_MARK_SEEN=true

# =========================
# AI / Gemini
# =========================
AI_ENABLED=true
AI_PROVIDER=gemini

# Use one key or multiple comma-separated keys
GEMINI_API_KEY=
GEMINI_API_KEYS=

GEMINI_MODEL=gemini-2.5-flash
CHANNEL_LANGUAGE=uk

# =========================
# Channel CTA
# =========================
CHANNEL_CTA_TEXT=📲 Subscribe to Smart News
CHANNEL_CTA_URL=https://t.me/smart_news_ua

# =========================
# FFmpeg / FFprobe
# =========================
FFMPEG_BIN=/opt/homebrew/opt/ffmpeg-full/bin/ffmpeg
FFPROBE_BIN=/opt/homebrew/opt/ffmpeg-full/bin/ffprobe

# =========================
# yt-dlp
# =========================
YTDLP_ENABLED=true
YTDLP_BIN=yt-dlp

# =========================
# Watermark branding
# =========================
WATERMARK_TEXT=Smart News UA
WATERMARK_LOGO_PATH=data/images/smart_news_ua_logo.png
WATERMARK_MARGIN=32

# Small watermark preset
WATERMARK_IMAGE_LOGO_SCALE=0.06
WATERMARK_IMAGE_TEXT_SCALE=0.022

WATERMARK_VIDEO_LOGO_SCALE=0.06
WATERMARK_VIDEO_TEXT_SCALE=0.022

# =========================
# Media behavior
# =========================
VIDEO_SOURCE_TEXT=🎥 Video: Suspilne
TELEGRAM_MEDIA_CAPTION_LIMIT=1024
TELEGRAM_MAX_MEDIA_IMAGES=4
MAX_VIDEO_UPLOAD_MB=45

# =========================
# Debug
# =========================
MEDIA_DEBUG=true